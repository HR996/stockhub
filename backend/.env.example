DATABASE_URL=postgresql+psycopg://istock:istock@localhost:5432/istock
PRECONFIGURED_USERS=admin,alice,bob
ADMIN_PASSWORD_HASH=

# Tushare Pro token — required for weekly SW industry sync.
# Get one at https://tushare.pro/user/token after activating a 2000+ point account.
TUSHARE_TOKEN=

# Daily stock_basic/trade_calendar/K-line/market-cap scheduler.
# Runs after A-share market close in Asia/Shanghai.
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=18
SCHEDULER_MINUTE=30
SCHEDULER_TRIGGERED_BY=scheduler

# Weekly SW industry sync scheduler (default OFF; enable in prod).
SCHEDULER_SW_ENABLED=false
SCHEDULER_SW_DAY_OF_WEEK=sat
SCHEDULER_SW_HOUR=2
SCHEDULER_SW_MINUTE=7
